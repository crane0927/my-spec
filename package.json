{
  "name": "myspec",
  "version": "0.1.0",
  "description": "Spec-driven development CLI for AI coding assistant workflows",
  "license": "MIT",
  "type": "module",
  "bin": {
    "myspec": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "release:check": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "yaml": "^2.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
